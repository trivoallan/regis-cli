{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Playbook Result",
  "type": "object",
  "required": [
    "playbook_name",
    "score",
    "total_scorecards",
    "passed_scorecards",
    "pages"
  ],
  "properties": {
    "playbook_name": {
      "type": "string"
    },
    "sidebar": {
      "type": "object"
    },
    "version": {
      "type": ["string", "null"]
    },
    "tier": {
      "type": ["string", "null"],
      "description": "The earned tier (e.g. Gold, Silver, Bronze) based on playbook conditions."
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "class"],
        "properties": {
          "slug": { "type": "string" },
          "scope": { "type": "string" },
          "value": { "type": ["string", "null"] },
          "class": {
            "type": "string",
            "enum": ["success", "warning", "error", "information"]
          },
          "label": {
            "type": "string",
            "description": "The full label string (scope or scope: value)."
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "passed", "status", "message"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "level": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "passed": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "incomplete"]
          },
          "message": { "type": "string" },
          "analyzers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "rules_summary": {
      "type": "object",
      "required": ["score", "total", "passed"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "total": { "type": "array", "items": { "type": "string" } },
        "passed": { "type": "array", "items": { "type": "string" } },
        "by_tag": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["rules", "passed_rules", "score"],
            "properties": {
              "rules": { "type": "array", "items": { "type": "string" } },
              "passed_rules": {
                "type": "array",
                "items": { "type": "string" }
              },
              "score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "total_scorecards": {
      "type": "integer",
      "minimum": 0
    },
    "passed_scorecards": {
      "type": "integer",
      "minimum": 0
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "score",
          "total_scorecards",
          "passed_scorecards",
          "sections"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "slug": {
            "type": ["string", "null"]
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "total_scorecards": {
            "type": "integer",
            "minimum": 0
          },
          "passed_scorecards": {
            "type": "integer",
            "minimum": 0
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "name",
                "score",
                "total_scorecards",
                "passed_scorecards",
                "scorecards"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "hint": {
                  "type": "string"
                },
                "score": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                },
                "total_scorecards": {
                  "type": "integer",
                  "minimum": 0
                },
                "passed_scorecards": {
                  "type": "integer",
                  "minimum": 0
                },
                "levels_summary": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "required": ["total", "passed", "percentage"],
                    "properties": {
                      "total": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "passed": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "percentage": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100
                      }
                    }
                  }
                },
                "tags_summary": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "required": ["total", "passed", "percentage"],
                    "properties": {
                      "total": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "passed": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "percentage": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100
                      }
                    }
                  }
                },
                "scorecards": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "title", "passed"],
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "level": {
                        "type": ["string", "null"]
                      },
                      "tags": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "analyzers": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "passed": {
                        "type": "boolean"
                      },
                      "status": {
                        "type": "string",
                        "enum": ["passed", "failed", "incomplete"]
                      },
                      "condition": {
                        "type": "string"
                      },
                      "details": {
                        "type": "string"
                      }
                    }
                  }
                },
                "display": {
                  "type": "object",
                  "properties": {
                    "analyzers": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "widgets": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "value": {
                            "type": "string"
                          },
                          "icon": {
                            "type": "string"
                          },
                          "resolved_value": {}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "mr_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "directory": { "type": "string" }
        }
      },
      "description": "Cookiecutter templates to be run for MR descriptions."
    }
  }
}
